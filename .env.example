# Copy to .env and fill in values.
# To load automatically, install python-dotenv and call load_dotenv() in config.py.
# Otherwise: export $(grep -v '^#' .env | xargs) before running, or use a systemd EnvironmentFile=.

# Path to the watchlist file (default: anime.toml in the working directory)
#ANIME_FILE=anime.toml

# Transmission JSON-RPC endpoint
#TRANSMISSION_URL=http://localhost:9091/transmission/rpc

# Transmission credentials (leave unset if auth is disabled)
#TRANSMISSION_USER=
#TRANSMISSION_PASS=

# Directory where torrents are saved (default: ~/Downloads)
#LYDARR_DEFAULT_DIR=/home/user/Downloads

# Web UI credentials for HTTP Basic Auth (leave unset to disable auth — LAN-only or trusted network)
# Set both to enable authentication. Required when exposing the UI over Tailscale or the internet.
#LYDARR_USER=admin
#LYDARR_PASS=changeme

# Set to 1 to run the web UI alongside the daemon
#LYDARR_WEB=1

# Web UI bind address and port
#LYDARR_WEB_HOST=0.0.0.0
#LYDARR_WEB_PORT=8080
